# Program run mode: dev or prod
# dev — logs to screen and file, stops on the first error
# prod — logs to file only, errors are skipped (default)
MODE=prod

# Log file path (relative paths are resolved next to the binary). Default: tmp/dev.log
LOG_PATH=tmp/dev.log

# Output directory for results. If empty — the directory being scanned is used.
OUTPUT_DIR=

# Active model from ./models: tiny, small, medium or large-v3
WHISPER_MODEL=medium

# Transcription language (auto = auto-detect, uk, ru, en, etc.)
WHISPER_LANG=auto

# Disable GPU/Metal for whisper
WHISPER_NO_GPU=false

# Maximum number of files processed concurrently (positive integer). Default: 4
MAX_WORKERS=4

# Speaker diarization via sherpa-onnx (requires the binary and models, see README)
DIARIZE=false

# Expected number of speakers (0 = auto-detect)
DIARIZE_SPEAKERS=0

# Speaker label prefix in the output ("speaker-" -> "**speaker-1:**"; e.g. "актор" -> "**актор1:**")
DIARIZE_LABEL=speaker-

# Clustering threshold for speaker auto-detection (0 = sherpa default 0.5).
# Lower values split voices more aggressively (e.g. 0.3). Ignored when DIARIZE_SPEAKERS > 0.
DIARIZE_THRESHOLD=0

# Diarization engine: sherpa (default, external binary + ONNX models)
# or pyannote (local Python with pyannote.audio — better quality, see README)
DIARIZE_ENGINE=sherpa

# Python interpreter for the pyannote engine (may point into a virtualenv)
DIARIZE_PYTHON=python3
